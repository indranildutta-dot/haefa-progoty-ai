rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Fetches user document once and caches it for the request
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user is a global admin
    function isGlobalAdmin() {
      return request.auth != null && request.auth.token.role == 'global_admin';
    }

    match /patients/{patientId} {
      // 1. Global Admin has full access
      // 2. Doctors/Nurses can read if clinicId matches their assignedClinics
      allow read: if request.auth != null && (
        isGlobalAdmin() || 
        resource.data.clinicId in getUserData().assignedClinics
      );
      
      // Only allow write if user is approved and assigned to the clinic
      allow write: if request.auth != null && 
                      getUserData().isApproved == true &&
                      request.resource.data.clinicId in getUserData().assignedClinics;
    }
    
    // Access control for users
    match /users/{userId} {
      allow read: if request.auth != null && (isGlobalAdmin() || request.auth.uid == userId);
      allow write: if request.auth != null && (isGlobalAdmin() || request.auth.uid == userId);
    }
  }
}
