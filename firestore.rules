rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isGlobalAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "iJaFyejOXrNbGrrA9es4IN7Ykum2" ||
        ("email" in request.auth.token && (
          request.auth.token.email == "indranil_dutta@haefa.org" ||
          request.auth.token.email == "ruhul_abid@haefa.org"
        )) ||
        getUserData().get('role', '') == 'global_admin'
      );
    }

    function isCountryAdmin(countryId) {
      return isGlobalAdmin() || (
        isAuthenticated() && 
        getUserData().get('role', '') == 'country_admin' && 
        countryId in getUserData().get('assignedCountries', [])
      );
    }

    function isPharmacist(clinicId) {
      return isGlobalAdmin() || (
        isAuthenticated() && 
        getUserData().get('role', '') == 'pharmacist' && 
        clinicId in getUserData().get('assignedClinics', [])
      );
    }

    function isDoctorOrNurse() {
      return isGlobalAdmin() || (
        isAuthenticated() && 
        (getUserData().get('role', '') == 'doctor' || getUserData().get('role', '') == 'nurse')
      );
    }

    function isApproved() {
      return isGlobalAdmin() || (
        isAuthenticated() && 
        getUserData().get('isApproved', false) == true
      );
    }

    function isStaff(clinicId) {
      return isGlobalAdmin() || (
        isAuthenticated() && 
        clinicId in getUserData().get('assignedClinics', [])
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidPatient(data) {
      return data.keys().hasAll(['given_name', 'family_name', 'gender', 'country_id', 'clinic_id']) &&
             data.given_name is string && data.given_name.size() > 0 && data.given_name.size() < 100 &&
             data.family_name is string && data.family_name.size() > 0 && data.family_name.size() < 100 &&
             data.gender in ['male', 'female', 'other'] &&
             data.country_id is string &&
             data.clinic_id is string &&
             (!('date_of_birth' in data) || data.date_of_birth is string) &&
             (!('age_years' in data) || data.age_years is string || data.age_years is number);
    }

    function isValidEncounter(data) {
      return data.keys().hasAll(['patient_id', 'status', 'country_id', 'clinic_id']) &&
             data.patient_id is string &&
             data.status is string &&
             data.country_id is string &&
             data.clinic_id is string;
    }

    function isValidVitals(data) {
      return data.keys().hasAll(['patient_id', 'encounter_id', 'clinic_id']) &&
             data.patient_id is string &&
             data.encounter_id is string &&
             data.clinic_id is string;
    }

    function isValidMedication(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidBatch(data) {
      return data.keys().hasAll(['medication_id', 'batch_id', 'expiry_date', 'quantity', 'base_unit', 'package_unit']) &&
             data.medication_id is string && data.batch_id is string &&
             data.expiry_date is timestamp &&
             data.quantity is number && data.quantity >= 0 &&
             data.base_unit is string && data.package_unit is string;
    }

    function isValidQueueItem(data) {
      return data.keys().hasAll(['patient_id', 'encounter_id', 'clinic_id', 'status', 'station']) &&
             data.patient_id is string &&
             data.encounter_id is string &&
             data.clinic_id is string &&
             data.status is string &&
             data.station is string;
    }

    function isValidDailySummary(data) {
      return data.keys().hasAll(['date', 'clinic_id', 'country_id', 'total_patients']) &&
             data.date is string &&
             data.clinic_id is string &&
             data.country_id is string &&
             data.total_patients is number;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /daily_summaries/{summaryId} {
      // Analytical data access restricted to staff and admins
      allow read: if isApproved() && (
        isGlobalAdmin() ||
        resource.data.country_id in getUserData().get('assignedCountries', []) ||
        resource.data.clinic_id in getUserData().get('assignedClinics', [])
      );
      // Aggregation is handled by server-side Cloud Functions (Admin SDK)
      // Only Global Admins can manually correct metrics
      allow write: if isGlobalAdmin();
    }

    match /patients/{patientId} {
      allow read: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(resource.data.country_id) ||
        isStaff(resource.data.clinic_id)
      );
      
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(request.resource.data.country_id) ||
        isStaff(request.resource.data.clinic_id)
      ) && isValidPatient(request.resource.data);

      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(resource.data.country_id) ||
        isStaff(resource.data.clinic_id)
      ) && (
        // Ensure clinic_id and country_id don't change unless admin
        (isGlobalAdmin() || (
          request.resource.data.clinic_id == resource.data.clinic_id &&
          request.resource.data.country_id == resource.data.country_id
        ))
      ) && isValidPatient(request.resource.data);

      allow delete: if isGlobalAdmin();
    }

    match /encounters/{encounterId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(request.resource.data.country_id) ||
        isStaff(request.resource.data.clinic_id)
      ) && isValidEncounter(request.resource.data);
      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(resource.data.country_id) ||
        isStaff(request.resource.data.clinic_id)
      );
    }

    match /encounters_archive/{encounterId} {
      allow read: if isApproved();
      allow write: if isGlobalAdmin();
    }

    match /vitals/{vitalsId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(request.resource.data.clinic_id)
      ) && isValidVitals(request.resource.data);
      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(resource.data.clinic_id)
      );
    }

    match /diagnoses/{diagnosisId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(request.resource.data.clinic_id)
      );
      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(resource.data.clinic_id)
      );
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(request.resource.data.clinic_id)
      );
      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(resource.data.clinic_id)
      );
    }

    match /dispensations/{dispensationId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /triage_assessments/{assessmentId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(request.resource.data.clinic_id)
      );
      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isStaff(resource.data.clinic_id)
      );
    }

    match /queues_active/{queueId} {
      allow read: if isAuthenticated() && (
        isGlobalAdmin() || 
        isCountryAdmin(resource.data.country_id) ||
        isStaff(resource.data.clinic_id)
      );
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(request.resource.data.country_id) ||
        isStaff(request.resource.data.clinic_id)
      ) && isValidQueueItem(request.resource.data);
      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(request.resource.data.country_id) ||
        isStaff(request.resource.data.clinic_id)
      ) && isValidQueueItem(request.resource.data);
      allow delete: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(resource.data.country_id) ||
        isStaff(request.resource.data.clinic_id)
      );
    }

    match /queues_archive/{queueId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /clinic_metrics/{clinicId} {
      allow read: if isAuthenticated() && (
        isGlobalAdmin() || 
        isCountryAdmin(resource.data.country_id) ||
        isStaff(resource.data.clinic_id) ||
        isStaff(clinicId) ||
        // Allow reading metrics for the specific clinic even if ID is clinicId_today
        (clinicId.size() > 5 && isStaff(clinicId.split('_')[0]))
      );
      allow write: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(resource.data.country_id) ||
        isStaff(resource.data.clinic_id) ||
        isStaff(clinicId) ||
        // Allow writing metrics for the specific clinic even if ID is clinicId_today
        (clinicId.size() > 5 && isStaff(clinicId.split('_')[0]))
      );
    }

    match /country_metrics/{countryId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }

    match /global_metrics/{globalId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }

    match /countries/{countryId} {
      allow read: if isAuthenticated();
      allow write: if isGlobalAdmin();
    }

    match /clinics/{clinicId} {
      allow read: if isAuthenticated();
      allow write: if isGlobalAdmin();
    }

    match /badge_tokens/{tokenId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(request.resource.data.country_id) ||
        isStaff(request.resource.data.clinic_id)
      );
      allow update: if isApproved() && (
        isGlobalAdmin() ||
        isCountryAdmin(resource.data.country_id) ||
        isStaff(resource.data.clinic_id)
      );
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isGlobalAdmin() || 
        (getUserData().get('role', '') == 'country_admin' && resource.data.country_id in getUserData().get('assignedCountries', []))
      );
      allow write: if isAuthenticated() && (
        request.auth.uid == userId ||
        isGlobalAdmin() || 
        (getUserData().get('role', '') == 'country_admin' && request.resource.data.country_id in getUserData().get('assignedCountries', []))
      );
    }

    match /audit_logs/{logId} {
      allow read: if isGlobalAdmin();
      allow create: if isAuthenticated();
    }

    // Pharmacy Module Rules
    match /medications_catalog/{medicationId} {
      allow read: if isAuthenticated();
      allow write: if isGlobalAdmin() && isValidMedication(request.resource.data);
    }

    match /patient_allergies/{allergyId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /medication_interactions/{interactionId} {
      allow read: if isApproved();
      allow write: if isGlobalAdmin();
    }

    match /clinics/{clinicId}/inventory/{batchId} {
      allow read: if isApproved() && (isGlobalAdmin() || isStaff(clinicId));
      allow write: if isApproved() && (isGlobalAdmin() || isStaff(clinicId));
    }

    match /inventory_logs/{logId} {
      allow read: if isApproved() && (isGlobalAdmin() || isStaff(resource.data.clinic_id));
      allow create: if isAuthenticated();
    }

    match /requisitions/{reqId} {
      allow read: if isApproved() && (isGlobalAdmin() || isStaff(resource.data.clinic_id));
      allow write: if isApproved() && (isGlobalAdmin() || isStaff(request.resource.data.clinic_id));
    }
    match /icd11_common/{code} {
      allow read: if isAuthenticated();
      allow write: if isGlobalAdmin();
    }
  }
}
