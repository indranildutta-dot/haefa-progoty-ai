{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "A patient registered in the system",
      "type": "object",
      "properties": {
        "given_name": { "type": "string", "description": "First name of the patient" },
        "family_name": { "type": "string", "description": "Last name of the patient" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "date_of_birth": { "type": "string", "format": "date" },
        "age_years": { "type": "number" },
        "age_months": { "type": "number" },
        "age_days": { "type": "number" },
        "phone": { "type": "string" },
        "marital_status": { "type": "string", "enum": ["single", "married", "divorced", "widowed", "separated"] },
        "national_id": { "type": "string", "description": "National ID Number (Bangladesh or Nepal)" },
        "rohingya_number": { "type": "string", "description": "Rohingya Refugee Number (Bangladesh only)" },
        "bhutanese_refugee_number": { "type": "string", "description": "Bhutanese Refugee Number (Nepal only)" },
        "address_type": { "type": "string", "enum": ["home", "refugee camp"] },
        "address_line": { "type": "string" },
        "village": { "type": "string" },
        "thana": { "type": "string" },
        "post_code": { "type": "string" },
        "district": { "type": "string" },
        "country": { "type": "string" },
        "photo_url": { "type": "string" },
        "country_id": { "type": "string" },
        "clinic_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["given_name", "family_name", "gender", "country_id", "clinic_id"]
    }
  },
  "firestore": {
    "patients": {
      "schema": "Patient",
      "description": "Collection of patients"
    },
    "clinic_metrics": {
      "schema": "object",
      "description": "Daily metrics for each clinic"
    },
    "country_metrics": {
      "schema": "object",
      "description": "Daily metrics for each country"
    },
    "global_metrics": {
      "schema": "object",
      "description": "Daily global metrics"
    },
    "qr_tokens": {
      "schema": "object",
      "description": "Mapping of QR tokens to patient IDs"
    }
  }
}
