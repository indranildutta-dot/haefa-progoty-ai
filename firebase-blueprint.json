{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "A patient registered in the system",
      "type": "object",
      "properties": {
        "given_name": { "type": "string", "description": "First name of the patient" },
        "family_name": { "type": "string", "description": "Last name of the patient" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "date_of_birth": { "type": "string", "format": "date" },
        "estimated_birth_year": { "type": "number" },
        "is_minor": { "type": "boolean" },
        "parent_name": { "type": "string" },
        "parent_id": { "type": "string" },
        "age_years": { "type": "number" },
        "age_months": { "type": "number" },
        "age_days": { "type": "number" },
        "phone": { "type": "string" },
        "marital_status": { "type": "string", "enum": ["single", "married", "divorced", "widowed", "separated"] },
        "national_id": { "type": "string", "description": "National ID Number (Bangladesh or Nepal)" },
        "rohingya_number": { "type": "string", "description": "Rohingya Refugee Number (Bangladesh only)" },
        "bhutanese_refugee_number": { "type": "string", "description": "Bhutanese Refugee Number (Nepal only)" },
        "address_type": { "type": "string", "enum": ["home", "refugee camp"] },
        "address_line": { "type": "string" },
        "village": { "type": "string" },
        "thana": { "type": "string" },
        "upazila": { "type": "string" },
        "union": { "type": "string" },
        "post_code": { "type": "string" },
        "district": { "type": "string" },
        "country": { "type": "string" },
        "permanent_address_same_as_present": { "type": "boolean" },
        "perm_address_line": { "type": "string" },
        "perm_village": { "type": "string" },
        "perm_district": { "type": "string" },
        "perm_upazila": { "type": "string" },
        "perm_union": { "type": "string" },
        "perm_post_code": { "type": "string" },
        "perm_country": { "type": "string" },
        "photo_url": { "type": "string" },
        "country_id": { "type": "string" },
        "clinic_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["given_name", "family_name", "gender", "country_id", "clinic_id"]
    },
    "Medication": {
      "title": "Medication",
      "description": "Global master list of medications",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "generic_name": { "type": "string" },
        "form": { "type": "string" },
        "strength": { "type": "string" },
        "cold_chain_req": { "type": "boolean" },
        "base_unit": { "type": "string" },
        "package_unit": { "type": "string" },
        "package_size": { "type": "number" }
      },
      "required": ["name", "generic_name", "form", "strength", "base_unit"]
    },
    "Batch": {
      "title": "Batch",
      "description": "Inventory batch details",
      "type": "object",
      "properties": {
        "batch_id": { "type": "string" },
        "expiry_date": { "type": "string", "format": "date" },
        "current_qty": { "type": "number" },
        "medication_id": { "type": "string" }
      },
      "required": ["batch_id", "expiry_date", "current_qty", "medication_id"]
    },
    "InventoryLog": {
      "title": "InventoryLog",
      "description": "Audit trail for inventory changes",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["receive", "dispense", "waste"] },
        "qty": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "medication_id": { "type": "string" },
        "batch_id": { "type": "string" },
        "clinic_id": { "type": "string" }
      },
      "required": ["user_id", "type", "qty", "timestamp", "medication_id", "clinic_id"]
    },
    "DailySummary": {
      "title": "DailySummary",
      "description": "Aggregated daily clinical and operational metrics",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "clinic_id": { "type": "string" },
        "country_id": { "type": "string" },
        "total_patients": { "type": "number" },
        "new_patients": { "type": "number" },
        "triage_counts": { "type": "object" },
        "gender_counts": { "type": "object" },
        "disease_prevalence": { "type": "object" },
        "avg_wait_times": { "type": "object" },
        "medication_volumes": { "type": "object" },
        "referral_reasons": { "type": "object" },
        "ncd_metrics": { "type": "object" },
        "maternal_health": { "type": "object" },
        "nutrition": { "type": "object" },
        "infectious_disease": { "type": "object" },
        "provider_metrics": { "type": "object" },
        "clinical_outcomes": { "type": "object" },
        "operational_efficiency": { "type": "object" },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "clinic_id", "country_id", "total_patients"]
    }
  },
  "firestore": {
    "patients": {
      "schema": "Patient",
      "description": "Collection of patients"
    },
    "daily_summaries": {
      "schema": "DailySummary",
      "description": "Aggregated daily clinical and operational metrics for the Advanced Analytics portal"
    },
    "clinic_metrics": {
      "schema": "object",
      "description": "Daily metrics for each clinic"
    },
    "country_metrics": {
      "schema": "object",
      "description": "Daily metrics for each country"
    },
    "global_metrics": {
      "schema": "object",
      "description": "Daily global metrics"
    },
    "badge_tokens": {
      "schema": "object",
      "description": "Mapping of QR tokens to patient IDs"
    },
    "medications_catalog": {
      "schema": "Medication",
      "description": "Global master list of medications"
    },
    "clinics/{clinicId}/inventory": {
      "schema": "Batch",
      "description": "Inventory batches for each clinic"
    },
    "inventory_logs": {
      "schema": "InventoryLog",
      "description": "Audit trail for inventory changes"
    }
  }
}
